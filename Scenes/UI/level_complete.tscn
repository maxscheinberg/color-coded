[gd_scene format=3 uid="uid://level_complete_001"]

[ext_resource type="Script" path="res://Scripts/UI/level_complete.gd" id="1_lcscr"]
[ext_resource type="FontFile" path="res://Assets/Fonts/PressStart2P-Regular.ttf" id="2_lcfnt"]

[node name="LevelComplete" type="CanvasLayer"]
script = ExtResource("1_lcscr")

[node name="Overlay" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.051, 0.051, 0.078, 0.82)

[node name="Panel" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
custom_minimum_size = Vector2(260, 0)
theme_override_constants/separation = 20
alignment = 1

[node name="ColorBar" type="HBoxContainer" parent="Panel/VBox"]
custom_minimum_size = Vector2(260, 5)
theme_override_constants/separation = 0

[node name="BarRed" type="ColorRect" parent="Panel/VBox/ColorBar"]
layout_mode = 2
size_flags_horizontal = 3
color = Color(0.91, 0.267, 0.267, 1)

[node name="BarYellow" type="ColorRect" parent="Panel/VBox/ColorBar"]
layout_mode = 2
size_flags_horizontal = 3
color = Color(0.961, 0.784, 0.259, 1)

[node name="BarBlue" type="ColorRect" parent="Panel/VBox/ColorBar"]
layout_mode = 2
size_flags_horizontal = 3
color = Color(0.267, 0.533, 0.933, 1)

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_lcfnt")
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "COMPLETE!"
horizontal_alignment = 1

[node name="MovesLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_lcfnt")
theme_override_font_sizes/font_size = 8
theme_override_colors/font_color = Color(1, 1, 1, 0.6)
text = "MOVES: 0"
horizontal_alignment = 1

[node name="BtnNext" type="Button" parent="Panel/VBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_lcfnt")
theme_override_font_sizes/font_size = 10
text = "NEXT LEVEL"

[connection signal="pressed" from="Panel/VBox/BtnNext" to="." method="_on_btn_next_pressed"]
